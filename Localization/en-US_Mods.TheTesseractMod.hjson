			'''
	}

	PrototypePSR1: {
		Tooltip: ""
		DisplayName: Prototype P S R1
	}

	TrueHolyCommander: {
		Tooltip:
			'''
			Summons a True Golden Mage to fight for you.
			The true golden mage will switch betwen attacking, where it will attack a target,
			and defending, where it will give the player random buffs. It has a bigger list of
			buffs to pick from.
			'''
		DisplayName: True Holy Commander
	}

	TerraTotem: {
		Tooltip:
			'''
			Summons an offensive Tiki Terra Spirit to fight for you..
			Consumes all minion slots, and the strength of the minion is determined by how 
			many slots are consumed
			Level 1: 0-3 slots.
			Level 2: 4-6 slots.
			Level 3: 7+ slots.
			'''
		DisplayName: Terra Totem
	}

	TerraTrident: {
		Tooltip:
			'''
			This weapon is to be used with the Terra Totem. 
			Shoots a terra spear that marks an enemy. Marked enemies will send the Terra Tiki Spirit
			into a melee frenzy which will heal the player for 10% of the damage dealt. Also will
			mark enemies like a whip.
			'''
		DisplayName: Terra Trident
	}

	Geom: {
		Tooltip: ""
		DisplayName: Geom
	}

	Sain_geom: {
		Tooltip:
			'''
			Landing consecutive blows allows for different combo attacks, and greated the ATTUNED buff!

			Reaching stage 3 of combos grants the user the SEALED buff, which allows the user to right-
			click dash attack and acts as a better ATTUNED buff.

			Gets buffed after defeating the Moon Lord
			'''
		DisplayName: Sain-Geom
	}

	Gok_Do: {
		Tooltip:
			'''
			A far more dynamic spear. Land consecutive hits to build up a PARRY charge. Increase in stages
			to have a better PARRY. Right click to PARRY. Parries will either completely destroy a projectile,
			or if they are super high damage (death rays), they will reduce in damage.
			Gets buffed after defeating the Moon Lord
			'''
		DisplayName: Gok-Do
	}

	Shin_Kal: {
		DisplayName: Shin-Kal
		Tooltip:
			'''
			Land consecutive hits to increase effectiveness. Right click to throw multiple knives and increase
