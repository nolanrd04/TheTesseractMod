# This file will automatically update with entries for new content after a build and reload

Items: {
	funniSword: {
		DisplayName: funni Sword
		Tooltip: I didn't feel like deleting this.
	}

	ConjuringClimax: {
		DisplayName: Conjuring Climax
		Tooltip:
			'''
			Casts 5 Zenith Missles and a rainbow missle that all chase 
			your enemies and explode into a multi-magic fury. Also hurls 
			Crystal Breath and Shadow Beams.
			'''
	}

	PrimeMeridian: {
		DisplayName: Prime Meridian
		Tooltip:
			'''
			"HE'S A WIIIZZZAAARD!"

			Casts 3 homing energy spheres, a supercharged 
			magic spell, and lots of close range energy 
			flames that shred through your enemies.
			'''
	}

	ApexN31: {
		DisplayName: Apex N31
		Tooltip:
			'''
			66% chance not to consume ammo
			Shoots 2 bullets of choice and 4 random vanilla bullets.
			'''
	}

	Culmination: {
		DisplayName: Culmination
		Tooltip:
			'''
			50% chance not to consume ammo.
			"Better than a Power V bow!"
			Rains stars and arrows from the sky! Also 
			shoots arrows and a phantom pheonix straight
			out! Arrows shot straight out have a chance
			to be a super arrow.
			'''
	}

	DeathsSickle: {
		DisplayName: Death's Sickle
		Tooltip:
			'''
			"I just LOVE the smell of fear!"
			Shoots out red flames that home in on targets.
			Make sure to stay close!
			'''
	}

	ZenithWhip: {
		DisplayName: Pinnacle
		Tooltip:
			'''
			20 summon tag damage.
			Landing an attack increases attack speed.
			Unleashes a fury of different whips. Also
			throws whip counterweights, though this
			might be a bit... much.
			'''
	}

	ZenithSummonStaff: {
		DisplayName: Apogaios
		Tooltip:
			'''
			Summons a zenith star to fight for you
			The zenith star will strike your enemies,
			and also occasionally summon a random
			minion to fight for you!
			'''
	}

	HomingProjectileTestingStaff: {
		DisplayName: Homing Projectile Testing Staff
		Tooltip: ""
	}

	Tesseract1: {
		DisplayName: Tesseract (level 1)
		Tooltip:
			'''
			Teleports the player to spawn Consumes all mana and 100 hp.
			Your body is not ready for this...
			'''
	}

	AtomOfTime: {
		DisplayName: Atom Of Time
		Tooltip: Used to upgrade the Tesseract. Drops from bosses.
	}

	Tesseract2: {
		DisplayName: Tesseract (Level 2)
		Tooltip:
			'''
			Teleports you home.
			Now you're getting it...
			'''
	}

	TesseractPylonItem: {
		Tooltip:
			'''
			You need at least a level 3 tesseract to use this. Doesn't
			require NPC's.
			(Doesn't work in mutiplayer and idk why).
			'''
		DisplayName: Tesseract Pylon
	}

	Tesseract3: {
		DisplayName: Tesseract (Level 3)
		Tooltip:
			'''
			Has previous level abilities. If this is inventory, you can
			teleport to the tesseract pylon.
			'''
	}

	Tesseract4: {
		DisplayName: Tesseract (Level 4)
		Tooltip:
			'''
			Has previous level abilities. Allows the user to teleport to the
			dungeon pylon. Pylon has to be in the dungeon biome in order to be used.
			'''
	}

	DungeonPylonItem: {
		DisplayName: Dungeon Pylon
		Tooltip:
			'''
			Pylon has to be in the dungeon in order to be used.
			You need a level 4+ tesseract to interact
			'''
	}

	Tesseract5: {
		DisplayName: Tesseract (Level 5)
		Tooltip:
			'''
			Has previous level abilites. Right click to switch between functions.
			Function 1 (Recall):
				Teleports you home.
			Function 2 (Time Warp):
				Hold down to speed up time.
			'''
	}

	Tesseract6: {
		DisplayName: Tesseract (Level 6)
		Tooltip:
			'''
			Has previous level abilites. New ability: Phase Shift.
			Press TESSERACT TELEPORT KEY to teleport to the mouse cursor. Can be
			changed in controls and can be used from anywhere in the inventory.
			'''
	}

	Tesseract7: {
		DisplayName: Tesseract (Level 7)
		Tooltip:
			'''
			Has previous level abilites. New ability: Temporal Dash.
			Right click to switch between functions.
			Function 1 (Recall):
				Teleports you home.
			Function 2 (Time Warp):
				Hold down to speed up time.
			Function 3 (Temporal Dash):
				Using the item allows you to get out of a pickle by greatly increasing
				movement speed and life regeneration for 10 seconds. You can not attack during this time.
				1 minute cooldown.
			'''
	}

	Tesseract8: {
		DisplayName: Tesseract (Level 8)
		Tooltip:
			'''
			Has previous level abilities. New ability: Stardust Relocator.
			Press TESSERACT TELEPORT KEY to teleport in up to a burst of three. You have a 
			1 second window when you are allowed to teleport. Once that window closes or you 
			teleport 3 times, you will be inflicted with the chaos debuff.
			'''
	}

	Tesseract9: {
		DisplayName: Tesseract (Level 9)
		Tooltip:
			'''
			Has previous level abilites. New ability: Universal Pylon Locator. Allows you to
			teleport to any pylon from anywhere in the world if this is in your inventory.
			'''
	}

	Tesseract10: {
		DisplayName: Tesseract (Level 10)
		Tooltip:
			'''
			Has previous level abilites. New ability: Time Punch. 
			Right click to switch between abilities. Allows you to attack while the temporal 
			dash buff is active.
			'''
	}

	TesseractDeveloperItem: {
		Tooltip: ""
		DisplayName: Tesseract Developer Item
	}

	ThePeppermint: {
		DisplayName: The peppermint
		Tooltip:
			'''
			Mint Gaming's Official Weapon!
			After hitting an enemy, it will bounce off in the direction of another enemy.
			It is basically M.O.A.R. glaives from BTD 6 lol.
			WORM BOSSES BEWARE!
			'''
