	}

	TrueNightsLegatus: {
		Tooltip:
			'''
			Summons an advanced Night's crescent moon to fight for you.
			Stage 1: will ricochete between enemies rapidly. Amazing crowd control.
			Stage 2: will dash towards its target.
			'''
		DisplayName: True Nights Legatus
	}

	HolyCommander: {
		DisplayName: Holy Commander
		Tooltip:
			'''
			Summons a Golden Mage to fight for you.
			The golden mage will switch betwen attacking, where it will attack a target,
